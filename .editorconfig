[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = tabs
indent_size = 2

[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[{package,tsconfig}.json,.{editorconfig},*.{yml,yaml]
indent_style = space
indent_size = 2
