---
import FormattedDate from "./FormattedDate.astro";
import { getEntry, render } from "astro:content";
import { format } from "date-fns";

interface Props {
  element: string;
  id: string;
}

const { element = "article", id } = Astro.props;
const post = await getEntry("post", id);

if (!post) {
  throw new Error(`Unable to find post:${id}`);
}

const { title, date, slug } = post.data;
const rendered = await render(post);
const { Content } = rendered;

const Element = element;
---

<Element class="post" data-post-id={id}>
  {
    title && (
      <header>
        <h2 set:html={title}></h2>
      </header>
    )
  }

  <div class="content">
    <Content />
  </div>

  <footer>
    <p>
      <a rel="permalink" href={`/${slug}/`}>
        <FormattedDate {date} />
      </a>
    </p>
    <slot name="footer"></slot>
  </footer>
</Element>
