---
import FormattedDate from "./FormattedDate.astro";
import PostContent from "./PostContent.astro";
import { getEntry, render } from "astro:content";
import type { HTMLTag } from "astro/types";

interface Props {
	element: HTMLTag;
	id: string;
}

const { element = "article", id } = Astro.props;
const post = await getEntry("post", id);

if (!post) {
	throw new Error(`Unable to find post:${id}`);
}

const { title, date, slug } = post.data;
const rendered = await render(post);
const Element = element;
---

<Element class="h-entry" data-post-id={id} {...Astro.props}>
	{
		title && (
			<header>
				<h2 class="p-name" set:html={title} />
			</header>
		)
	}

	<PostContent {rendered} />

	<footer>
		<p>
			<a class="u-url" rel="permalink" href={`/${slug}/`}>
				<FormattedDate {date} />
			</a>

			<a
				class="p-author h-card"
				href="https://florianpichler.de"
				rel="author"
				hidden>Florian Pichler</a
			>
		</p>
		<slot name="footer" />
	</footer>
</Element>

<style>
header,
	 footer {
		margin-inline: auto;
		max-width: var(--max-width);
	}

	header {
		margin-bottom: var(--spacing-xl);
		font-size: 1.5rem;
		font-weight: 700;
	}

	footer {
		margin-top: 1lh;
		color: var(--fg-muted);
	}

	footer small {
		display: block;
		font-size: 0.75em;
		opacity: 0.5;
	}

	footer a {
		color: inherit;
		text-decoration: none;
	}
</style>
