---
export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  "data-orientation"?: string;
  postId?: string;
}

const { src, alt, width, height, postId, ...rest } = Astro.props;

let imageSrc = src;

if (src && !src.startsWith("http") && !src.startsWith("/")) {
  let resolvedPostId = postId;

  if (!resolvedPostId) {
    const url = Astro.url.pathname;
    const pathParts = url.split('/');

    if (pathParts.length >= 2) {
      const slugPart = pathParts[1];
      if (slugPart && slugPart.includes('ylkgd')) {
        resolvedPostId = slugPart.replace(/ylkgd$/, '@ylk.gd');
      }
    }
  }

  if (resolvedPostId) {
    imageSrc = `/posts/${resolvedPostId}/${src}`;
  }
}
---

<img
  src={imageSrc}
  alt={alt}
  width={width}
  height={height}
  {...rest}
/>