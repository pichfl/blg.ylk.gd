---
const { page } = Astro.props;

const prev = page.currentPage === 2 ? "/" : page.url.prev;
const next = page.url.next;
const total = Math.ceil(page.total / page.size);
---

<nav class="pagination">
	{
		prev ? (
			<a href={prev}>
				<span role="presentation">&larr;</span> Newer
			</a>
		) : (
			<span>&nbsp;</span>
		)
	}
	<span>
		{page.currentPage} / {total}
	</span>
	{
		next ? (
			<a href={next}>
				Older <span role="presentation">&rarr;</span>
			</a>
		) : (
			<span>&nbsp;</span>
		)
	}
</nav>


<style>
	.pagination {
		display: flex;
		margin-inline: auto;
		width: var(--max-width);
		justify-content: space-between;
		gap: var(--spacing-lg);
	}

	.pagination > * {
		flex: 1 1 33%;
	}

	.pagination > :first-child {
		text-align: left;
	}

	.pagination > :last-child {
		text-align: right;
	}

	a {
		text-decoration: none;
	}

</style>
